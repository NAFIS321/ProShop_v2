{
  "name": "proshop-v2",
  "version": "1.0.0",
  "description": "eCommerce application built with the MERN stack",
  "homepage": "https://github.com/NAFIS321/ProShop_v2#readme",
  "bugs": {
    "url": "https://github.com/NAFIS321/ProShop_v2/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NAFIS321/ProShop_v2.git"
  },
  "license": "MIT",
  "author": "Nafis Ahmmed",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "server": "nodemon backend/server.js",
    "client": "npm start --prefix fronted",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "data:import": "node backend/seeder.js",
    "data:destroy": "node backend/seeder.js -d",
    "build": "npm install && npm install --prefix fronted && npm run build --prefix fronted"

  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "colors": "^1.4.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.3",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "nodemon": "^3.1.14"
  }
}
